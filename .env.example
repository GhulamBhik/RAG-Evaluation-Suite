# Example environment variables for RAG Evaluation Suite

# GROQ Used as a Judge
GROQ_API_KEY=your_groq_api_key_here

# Model selection used for tests/evaluation
MODEL_NAME=llama-3.3-70b-versatile

# Paths for test inputs and outputs (relative to project root)
TEST_CASES_PATH=data/sample_inputs/test_cases.json
RESULTS_JSON_PATH=data/sample_outputs/results.json
RESULTS_CSV_PATH=data/sample_outputs/results.csv
